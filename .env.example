# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# AI
GOOGLE_AI_KEY=your_google_ai_key

# Frontend (Vite)
VITE_API_BASE=http://localhost:3001/api

# Backend Environment Variables
PORT=5000
NODE_ENV=development
JWT_SECRET=              # Required for token generation
FRONTEND_URL=            # URL of the React frontend (e.g., http://localhost:5173)

# Database Strategy
DATABASE_URL=            # Full connection string (PostgreSQL)

# GitHub OAuth Integration
GITHUB_CLIENT_ID=        # From GitHub Developer Settings
GITHUB_CLIENT_SECRET=    # From GitHub Developer Settings
GITHUB_REDIRECT_URI=     # e.g., http://localhost:5000/api/auth/github/callback

# AI & Intelligence
GOOGLE_AI_KEY=           # Gemini 1.5 Flash API Key
